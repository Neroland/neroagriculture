{
  "schemaVersion": 1,
  "id": "${mod_id}",
  "version": "${mod_version}",
  "name": "${mod_name}",
  "description": "NeroAgriculture - multiloader build (Fabric).",
  "authors": ["${mod_authors}"],
  "license": "${mod_license}",
  "accessWidener": "neroagriculture.accesswidener",
  "environment": "*",
  "entrypoints": {
    "main": ["za.co.neroland.neroagriculture.fabric.NeroAgricultureFabric"],
    "client": ["za.co.neroland.neroagriculture.fabric.NeroAgricultureFabricClient"]
  },
  "mixins": [
    "neroagriculture-common.mixins.json",
    "neroagriculture.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=${fabric_loader_version}",
    "minecraft": ">=${minecraft_version}",
    "java": ">=21",
    "fabric-api": "*"
  }
}
